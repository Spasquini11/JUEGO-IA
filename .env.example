# .env.example — PLANTILLA (sin secretos). Este archivo SÍ se versiona.
#
# Cómo se usa: cuando conectemos las cuentas externas, Santiago va a copiar
# este archivo a uno llamado ".env.local" y ahí pegar las claves reales.
# El ".env.local" queda SOLO en tu compu y NUNCA se sube a internet.
#
# Por ahora está todo vacío: todavía no conectamos ninguna cuenta.

# --- Dirección base de la app (para armar los links mágicos) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (base de datos + login por link mágico) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (envío de emails) ---
RESEND_API_KEY=

# --- Anthropic / Claude (el coach de IA) ---
ANTHROPIC_API_KEY=
